[Unit]
Description=Vector Service
After=network-online.target
Wants=network-online.target

[Service]
User={{ vector_user }}
Group={{ vector_group }}
ExecStart={{ vector_install_dir }}/bin/vector --config {{ vector_config_dir }}/vector.toml
Restart=always
RestartSec=10
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target